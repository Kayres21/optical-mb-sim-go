{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Capacities Schema",
  "type": "object",
  "properties": {
    "bands": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "capacity": { "type": "integer" }
        },
        "required": ["id", "name", "capacity"]
      }
    }
  },
  "required": ["bands"]
}
